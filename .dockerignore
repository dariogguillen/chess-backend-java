# Build artifacts — the host's target/ is irrelevant because the
# Dockerfile produces the jar inside the builder stage. Excluding it
# keeps the build context small and avoids stale jars sneaking in.
target/

# Git metadata is not needed inside the image.
.git/
.gitignore
.gitattributes

# The Maven wrapper jar is regenerated by mvnw; don't ship the binary
# in the build context.
.mvn/wrapper/maven-wrapper.jar

# Editor / IDE artifacts.
.idea/
.vscode/
*.iml
.DS_Store

# Project documentation, harness state, and learning notes are not part
# of the runtime artifact.
notes/
progress/
docs/
.claude/
CHECKPOINTS.md
CLAUDE.md
AGENTS.md
